generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  DISABLED
}

enum RelationshipTag {
  FAMILY
  FRIEND
  PARTNER
  WORK
}

enum AddressValidationStatus {
  VALID
  INVALID
}

enum ContactAddressKind {
  PRIMARY
  ALTERNATE
}

enum TemplateCategory {
  BIRTHDAY
  GENERAL
  HOLIDAY
  THANK_YOU
  ANNIVERSARY
}

enum TemplateOrientation {
  PORTRAIT
  LANDSCAPE
}

enum TemplateFieldKind {
  TEXT
  TEXTAREA
  PHOTO
}

enum StoredObjectKind {
  PHOTO_UPLOAD
  RENDER_ARTIFACT
  PRINTABLE_ASSET
}

enum RenderPhotoFit {
  FIT
  COVER
}

enum MomentEventType {
  CONTACT_BIRTHDAY
  ONE_OFF_DATE
}

enum MomentDeliveryPreference {
  ARRIVE_BY
  SHIP_ON
}

enum MomentApprovalMode {
  ALWAYS_ASK
}

enum DraftStatus {
  SCHEDULED
  PROCESSING
  READY_FOR_REVIEW
  APPROVED
  SKIPPED
}

enum OrderStatus {
  AWAITING_PAYMENT
  PAYMENT_FAILED
  PAID
  FULFILLMENT_PENDING
  FULFILLED
  CANCELLED
}

enum ShippingType {
  STANDARD
  PRIORITY
}

enum ShippingZone {
  DOMESTIC
  INTERNATIONAL
}

enum PrintableAssetStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model User {
  id                  String                   @id @default(cuid())
  email               String                   @unique
  passwordHash        String?
  displayName         String?
  status              UserStatus               @default(PENDING_VERIFICATION)
  emailVerifiedAt     DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  addresses           Address[]
  contacts            Contact[]
  drafts              Draft[]
  momentRules         MomentRule[]
  orders              Order[]
  paymentEvents       PaymentWebhookEvent[]
  profile             SenderProfile?
  renderPreviews      RenderPreview[]
  storedObjects       StoredObject[]
  verificationTokens  EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
}

model Address {
  id               String                  @id @default(cuid())
  userId           String
  line1            String
  line2            String?
  city             String
  region           String?
  postalCode       String
  countryCode      String
  validationStatus AddressValidationStatus @default(VALID)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  contactLinks     ContactAddress[]
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, countryCode, postalCode, city])
}

model Contact {
  id              String          @id @default(cuid())
  userId          String
  firstName       String
  lastName        String
  relationshipTag RelationshipTag?
  birthday        DateTime?
  timezone        String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  addressLinks    ContactAddress[]
  drafts          Draft[]
  momentRules     MomentRule[]
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lastName, firstName])
}

model ContactAddress {
  id        String             @id @default(cuid())
  contactId String
  addressId String
  kind      ContactAddressKind
  createdAt DateTime           @default(now())
  address   Address            @relation(fields: [addressId], references: [id], onDelete: Cascade)
  contact   Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, addressId])
  @@index([contactId, kind])
  @@index([addressId])
}

model SenderProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  fullName          String?
  addressLine1      String?
  addressLine2      String?
  city              String?
  region            String?
  postalCode        String?
  countryCode       String?
  preferredLocale   String?
  preferredCurrency String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Template {
  id              String              @id
  slug            String              @unique
  name            String
  category        TemplateCategory
  summary         String
  description     String
  widthMm         Int
  heightMm        Int
  orientation     TemplateOrientation
  previewLabel    String
  previewHeadline String
  previewMessage  String
  accentHex       String
  surfaceHex      String
  textHex         String
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  fields          TemplateField[]
  drafts          Draft[]
  momentRules     MomentRule[]
  renderPreviews  RenderPreview[]

  @@index([category, isActive, name])
}

model TemplateField {
  id          String            @id
  templateId  String
  key         String
  label       String
  kind        TemplateFieldKind
  required    Boolean           @default(false)
  placeholder String?
  maxLength   Int?
  position    Int
  template    Template          @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, key])
  @@index([templateId, position])
}

model StoredObject {
  id               String           @id @default(cuid())
  userId           String?
  kind             StoredObjectKind
  bucket           String
  objectKey        String           @unique
  originalFilename String?
  contentType      String
  sizeBytes        Int
  checksumSha256   String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  draftPhotos            Draft[]         @relation("DraftPhoto")
  momentRulePhotos       MomentRule[]    @relation("MomentRulePhoto")
  orderArtifacts         Order[]         @relation("OrderArtifact")
  orderPhotos            Order[]         @relation("OrderPhoto")
  orderPrintableAssets   Order[]         @relation("OrderPrintableAsset")
  renderPreviewArtifacts RenderPreview[] @relation("RenderPreviewArtifact")
  renderPreviewPhotos    RenderPreview[] @relation("RenderPreviewPhoto")
  user             User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, kind, createdAt])
  @@index([kind, createdAt])
}

model RenderPreview {
  id               String         @id @default(cuid())
  userId           String
  templateId       String
  photoObjectId    String?
  artifactObjectId String         @unique
  headline         String
  message          String
  fieldValues      Json
  photoFit         RenderPhotoFit?
  createdAt        DateTime       @default(now())
  drafts           Draft[]
  updatedAt        DateTime       @updatedAt
  artifactObject   StoredObject   @relation("RenderPreviewArtifact", fields: [artifactObjectId], references: [id], onDelete: Cascade)
  photoObject      StoredObject?  @relation("RenderPreviewPhoto", fields: [photoObjectId], references: [id], onDelete: SetNull)
  template         Template       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([templateId, createdAt])
}

model MomentRule {
  id                 String                   @id @default(cuid())
  userId             String
  contactId          String
  templateId         String
  photoObjectId      String?
  name               String
  eventType          MomentEventType
  oneOffDate         DateTime?
  leadTimeDays       Int                      @default(7)
  deliveryPreference MomentDeliveryPreference @default(ARRIVE_BY)
  approvalMode       MomentApprovalMode       @default(ALWAYS_ASK)
  messageTemplate    String
  nextOccurrenceAt   DateTime?
  nextDraftAt        DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  contact            Contact                  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  drafts             Draft[]
  photoObject        StoredObject?            @relation("MomentRulePhoto", fields: [photoObjectId], references: [id], onDelete: SetNull)
  template           Template                 @relation(fields: [templateId], references: [id], onDelete: Cascade)
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, nextDraftAt])
  @@index([contactId, eventType])
}

model Draft {
  id              String         @id @default(cuid())
  userId          String
  momentRuleId    String
  contactId       String
  templateId      String
  photoObjectId   String?
  renderPreviewId String?
  status          DraftStatus    @default(SCHEDULED)
  scheduledFor    DateTime
  draftReadyAt    DateTime
  occurrenceDate  DateTime
  headline        String
  message         String
  fieldValues     Json
  photoFit        RenderPhotoFit?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  contact         Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  momentRule      MomentRule     @relation(fields: [momentRuleId], references: [id], onDelete: Cascade)
  photoObject     StoredObject?  @relation("DraftPhoto", fields: [photoObjectId], references: [id], onDelete: SetNull)
  renderPreview   RenderPreview? @relation(fields: [renderPreviewId], references: [id], onDelete: SetNull)
  template        Template       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([momentRuleId, occurrenceDate])
  @@index([userId, status, draftReadyAt])
  @@index([contactId, scheduledFor])
}

model Order {
  id                String         @id @default(cuid())
  userId            String
  draftId           String         @unique
  contactId         String
  contactFirstName  String
  contactLastName   String
  templateId        String
  templateSlug      String
  templateName      String
  templateWidthMm   Int
  templateHeightMm  Int
  templateOrientation TemplateOrientation
  templatePreviewLabel String
  templateAccentHex String
  templateSurfaceHex String
  templateTextHex   String
  renderPreviewId   String
  artifactObjectId  String
  printableAssetObjectId String?  @unique
  printableAssetStatus   PrintableAssetStatus @default(PENDING)
  printableAssetGeneratedAt DateTime?
  printableAssetError String?
  photoObjectId     String?
  status            OrderStatus    @default(AWAITING_PAYMENT)
  shippingType      ShippingType?
  shippingZone      ShippingZone?
  currency          String?
  subtotalCents     Int?
  taxCents          Int?
  totalCents        Int?
  stripeCheckoutSessionId String?  @unique
  stripePaymentIntentId   String?  @unique
  paidAt            DateTime?
  lastPaymentError  String?
  headline          String
  message           String
  fieldValues       Json
  photoFit          RenderPhotoFit?
  scheduledFor      DateTime
  occurrenceDate    DateTime
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  artifactObject    StoredObject   @relation("OrderArtifact", fields: [artifactObjectId], references: [id], onDelete: Restrict)
  printableAssetObject StoredObject? @relation("OrderPrintableAsset", fields: [printableAssetObjectId], references: [id], onDelete: SetNull)
  photoObject       StoredObject?  @relation("OrderPhoto", fields: [photoObjectId], references: [id], onDelete: SetNull)
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([artifactObjectId])
  @@index([userId, printableAssetStatus, createdAt])
}

model PaymentWebhookEvent {
  id            String   @id @default(cuid())
  userId        String?
  stripeEventId String   @unique
  eventType     String
  createdAt     DateTime @default(now())
  processedAt   DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, processedAt])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
