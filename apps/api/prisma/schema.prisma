generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  DISABLED
}

enum RelationshipTag {
  FAMILY
  FRIEND
  PARTNER
  WORK
}

enum AddressValidationStatus {
  VALID
  INVALID
}

enum ContactAddressKind {
  PRIMARY
  ALTERNATE
}

enum TemplateCategory {
  BIRTHDAY
  GENERAL
  HOLIDAY
  THANK_YOU
  ANNIVERSARY
}

enum TemplateOrientation {
  PORTRAIT
  LANDSCAPE
}

enum TemplateFieldKind {
  TEXT
  TEXTAREA
  PHOTO
}

model User {
  id                  String                   @id @default(cuid())
  email               String                   @unique
  passwordHash        String?
  displayName         String?
  status              UserStatus               @default(PENDING_VERIFICATION)
  emailVerifiedAt     DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  addresses           Address[]
  contacts            Contact[]
  profile             SenderProfile?
  verificationTokens  EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
}

model Address {
  id               String                  @id @default(cuid())
  userId           String
  line1            String
  line2            String?
  city             String
  region           String?
  postalCode       String
  countryCode      String
  validationStatus AddressValidationStatus @default(VALID)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  contactLinks     ContactAddress[]
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, countryCode, postalCode, city])
}

model Contact {
  id              String          @id @default(cuid())
  userId          String
  firstName       String
  lastName        String
  relationshipTag RelationshipTag?
  birthday        DateTime?
  timezone        String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  addressLinks    ContactAddress[]
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lastName, firstName])
}

model ContactAddress {
  id        String             @id @default(cuid())
  contactId String
  addressId String
  kind      ContactAddressKind
  createdAt DateTime           @default(now())
  address   Address            @relation(fields: [addressId], references: [id], onDelete: Cascade)
  contact   Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, addressId])
  @@index([contactId, kind])
  @@index([addressId])
}

model SenderProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  fullName          String?
  addressLine1      String?
  addressLine2      String?
  city              String?
  region            String?
  postalCode        String?
  countryCode       String?
  preferredLocale   String?
  preferredCurrency String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Template {
  id              String              @id
  slug            String              @unique
  name            String
  category        TemplateCategory
  summary         String
  description     String
  widthMm         Int
  heightMm        Int
  orientation     TemplateOrientation
  previewLabel    String
  previewHeadline String
  previewMessage  String
  accentHex       String
  surfaceHex      String
  textHex         String
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  fields          TemplateField[]

  @@index([category, isActive, name])
}

model TemplateField {
  id          String            @id
  templateId  String
  key         String
  label       String
  kind        TemplateFieldKind
  required    Boolean           @default(false)
  placeholder String?
  maxLength   Int?
  position    Int
  template    Template          @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, key])
  @@index([templateId, position])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
