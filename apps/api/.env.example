NODE_ENV=development

# Network
PORT=3001
APP_BASE_URL=http://localhost:3000

# Data and queues
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/moments?schema=public
REDIS_URL=redis://localhost:6379

# Object storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=moments-dev
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Auth and email
JWT_SECRET=change-me
EMAIL_FROM=Moment-to-Mail <no-reply@example.com>
